# PostgreSQL
POSTGRES_DB=genemunology_dev
POSTGRES_USER=genemunology
POSTGRES_PASSWORD=genemunology

# Backend
BACKEND_JWT_SECRET=change-me-dev-jwt-secret

# Firebase Admin (service account JSON como string)
FIREBASE_ADMIN_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Resend (emails reais)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Genemunology <no-reply@example.com>
