{
  "name": "my-project-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run start:dev --workspace apps/api",
    "build:web": "npm run build --workspace apps/web",
    "build:api": "npm run build --workspace apps/api",
    "test:api": "npm run test --workspace apps/api",
    "test:api:smoke": "npm run test:smoke --workspace apps/api",
    "test:api:full": "npm run test:full --workspace apps/api",
    "test:api:integration": "npm run test:integration --workspace apps/api",
    "test:api:e2e": "npm run test:e2e --workspace apps/api",
    "test:api:cov": "npm run test:cov --workspace apps/api",
    "typecheck:api": "npm run typecheck --workspace apps/api",
    "check:api": "npm run check --workspace apps/api",
    "test:web": "npm run test --workspace apps/web",
    "test:web:watch": "npm run test:watch --workspace apps/web",
    "lint:web": "npm run lint --workspace apps/web",
    "start:web": "npm run start --workspace apps/web",
    "start:api": "npm run start:prod --workspace apps/api",
    "test:app:full": "bash scripts/test-app-full.sh",
    "test:app:headed": "bash scripts/test-app-headed.sh",
    "dev": "docker compose -f containers/dev/docker-compose.dev.yml up",
    "dev:build": "docker compose -f containers/dev/docker-compose.dev.yml build",
    "dev:down": "docker compose -f containers/dev/docker-compose.dev.yml down",
    "dev:down:volumes": "docker compose -f containers/dev/docker-compose.dev.yml down -v"
  }
}
